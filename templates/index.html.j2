
{% extends "layout.html.j2" %}
{% block content %}
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-semibold">Latest updates</h1>
    <div class="text-sm text-gray-500">Total: {{ items|length }}</div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    {% for it in items %}
    <article class="bg-white rounded-xl shadow p-4 flex gap-4">
      {% if it.image %}
      <a href="{{ it.link }}" target="_blank" rel="nofollow noopener" class="shrink-0">
        <img src="{{ it.image }}" alt="" class="w-32 h-24 object-cover rounded-md">
      </a>
      {% endif %}
      <div class="min-w-0">
        <a href="{{ it.link }}" target="_blank" rel="nofollow noopener" class="font-medium hover:underline">
          {{ it.title }}
        </a>
        <div class="mt-1 text-xs text-gray-500">
          {{ it.source }} • {{ it.published_human }}
        </div>
        {% if it.summary %}
        <p class="mt-2 text-sm text-gray-700 line-clamp-2">{{ it.summary }}</p>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
{% endblock %}
